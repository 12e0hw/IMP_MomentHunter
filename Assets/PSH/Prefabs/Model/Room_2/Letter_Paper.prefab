  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u2026\uADF8\uB0A0 \uC774\uD6C4\uB85C \uC6B0\uB9B0 \uC81C\uB300\uB85C
    \uB300\uD654\uB97C \uD558\uC9C0 \uBABB\uD588\uC9C0.\r\n\uADF8\uB798\uB3C4 \uB098\uB294
    \uD56D\uC0C1 \uB124\uAC00 \uAD1C\uCC2E\uC740\uC9C0 \uAC71\uC815\uD588\uB2E8\uB2E4.\r\n\r\n\uB108\uC758
    \uAE30\uCE68 \uC18C\uB9AC, \uB108\uC758 \uBC1C\uC790\uAD6D \uC18C\uB9AC\u2026\r\n\uB2E4\uB978
    \uBC29\uC5D0 \uC788\uC5B4\uB3C4 \uB4E4\uB838\uC5B4.\r\n\uADF8\uB798\uC11C \uB124\uAC00
    \uAD1C\uCC2E\uC9C0 \uC54A\uB2E4\uB294 \uAC78 \uC54C \uC218 \uC788\uC5C8\uC5B4.\r\n\r\n\uB9D0\uB85C\uB294
    \uB2E4 \uBABB \uD588\uC9C0\uB9CC, \uB098\uB294 \uD56D\uC0C1 \uB108\uB97C \uC0DD\uAC01\uD558\uACE0
    \uC788\uC5C8\uB2E8\uB2E4..\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 78de2a21d2c39d041a7bb5dc70d7365b, type: 2}
