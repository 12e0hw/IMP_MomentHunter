  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "...We never really talked properly after that day.\r\nBut still\u2026
    I was always worried about you.\r\n\r\nYour coughing, your footsteps...\r\nEven
    from another room, I could hear them.\r\nThat\u2019s how I knew you weren\u2019t
    okay.\r\n\r\nI never said it out loud,\r\nbut you were always on my mind."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 78de2a21d2c39d041a7bb5dc70d7365b, type: 2}
  m_sharedMaterial: {fileID: 1174983916617414219, guid: 78de2a21d2c39d041a7bb5dc70d7365b, type: 2}
